# ---- Server ----
NODE_ENV=development
# Dedicated port (avoids colliding with the other ONDC apps on 3000/4000).
PORT=4090
LOG_LEVEL=info
# Comma-separated allowed origins for the dashboard frontend
CORS_ORIGIN=http://localhost:5190

# Optional shared admin token. If set, all /api routes require
# `Authorization: Bearer <token>`. Leave empty to disable (internal-only).
ADMIN_TOKEN=

# ---- Redis (same instance the mock service uses) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
# DB0 = business/workbench state, DB1 = mock-runner config cache
REDIS_DB_0=0
REDIS_DB_1=1
# Hard cap on keys returned per /api/redis/scan page
REDIS_SCAN_PAGE_SIZE=200

# ---- Observability upstreams ----
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
GRAFANA_URL=http://localhost:3005
# Service token used when proxying to Grafana's HTTP API (optional)
GRAFANA_API_TOKEN=
# Basic-auth fallback used when no token is set (Grafana default: admin/admin)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# The monitored service's health endpoint (aggregated into /api/health).
# NOTE: the service exposes health at the TOP-LEVEL /health (not under
# /mock/playground). Point this at wherever the service actually runs.
SERVICE_HEALTH_URL=http://localhost:3000/health
