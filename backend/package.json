{
    "name": "automation-monitoring-backend",
    "version": "0.1.0",
    "private": true,
    "description": "Read-only aggregation/proxy API for the ONDC admin monitoring dashboard (Redis business view + Prometheus/Loki/Grafana proxies).",
    "type": "commonjs",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "nodemon --exec tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "axios": "^1.18.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^26.0.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "nodemon": "^3.1.14",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^4.1.9"
    }
}
