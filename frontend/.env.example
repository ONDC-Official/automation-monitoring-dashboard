# =============================================================================
# ONDC Automation Monitoring Dashboard — Frontend Environment Variables
# =============================================================================
# Variables prefixed with VITE_ are bundled into the browser build.
# Variables without the prefix are Node.js only (Vite dev-server / build).
# Copy this file to .env.local to override values without touching .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth
# Credentials are validated server-side via POST /api/auth/login. Configure the
# username/password on the BACKEND (AUTH_USERNAME / AUTH_PASSWORD) — nothing
# auth-related is bundled into the browser anymore.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# API base URL (exposed to the browser via VITE_ prefix)
# Set to / for same-origin setups (dev via Vite proxy, prod on shared domain).
# Change to the full backend origin (e.g. http://localhost:4090) only if the
# frontend and backend are served from different origins.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/

# -----------------------------------------------------------------------------
# Backend (dev proxy — NOT exposed to the browser)
# The Vite dev-server forwards every /api request to this URL.
# In production the backend serves the frontend from the same origin,
# so no equivalent variable is needed there.
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:4090
